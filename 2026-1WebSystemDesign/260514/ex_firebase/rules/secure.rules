// ✅ secure 규칙 — 학기 프로젝트 기본 패턴
// 적용: Firebase 콘솔 → Firestore Database → 규칙 탭 → 붙여넣기 → 게시
// 검증: demo-Note12/05-rules-test.html에서 4가지 시나리오 다시 시도

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ───── 메모 (04 데모용) ─────
    match /memos/{memoId} {
      // 누구나 읽을 수 있는 공개 메모 (단, 로그인은 필수)
      allow read: if request.auth != null;

      // 새 메모 작성: 자기 authorId로만
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.authorId
                    && request.resource.data.text is string
                    && request.resource.data.text.size() < 500;

      // 수정/삭제: 자기 글만
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.authorId;
    }

    // ───── 방명록 (06 미니 실습용) ─────
    match /guestbook/{entryId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.authorId;
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.authorId;
    }

    // ───── 그 외 모든 컬렉션 — 차단 (안전 default) ─────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// ═══ 핵심 패턴 3가지 ═══
//
// 1) request.auth != null
//    → 로그인 사용자만 (가장 기본 보호)
//
// 2) request.auth.uid == request.resource.data.authorId
//    → 자기 authorId로만 *작성* (사칭 방지)
//    request.resource = 지금 쓰려는 데이터
//
// 3) request.auth.uid == resource.data.authorId
//    → 자기 글만 *수정·삭제* (남의 글 못 건드림)
//    resource = DB에 이미 있는 데이터
//
// 학기 프로젝트의 90% 보안 규칙은 이 3가지 조합.
